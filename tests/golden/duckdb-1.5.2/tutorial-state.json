{
  "ducklake_version": "1.0",
  "duckdb_version": "1.5.2",
  "backend": "sqlite",
  "tutorial_steps": [
    {
      "step": 1,
      "operation": "attach",
      "sql": "ATTACH 'ducklake:catalog.db' AS lake (DATA_PATH 'data/')",
      "expected_state": {
        "ducklake_metadata": [
          {"key": "ducklake_version", "value": "1"},
          {"key": "data_path", "value": "data/"}
        ]
      }
    },
    {
      "step": 2,
      "operation": "create_schema",
      "sql": "CREATE SCHEMA lake.main",
      "snapshot_id": 1,
      "expected_state": {
        "ducklake_schema": [
          {"schema_id": 1, "schema_name": "main", "begin_snapshot": 1, "end_snapshot": null}
        ]
      }
    },
    {
      "step": 3,
      "operation": "create_table",
      "sql": "CREATE TABLE lake.main.test_table (id INTEGER, name VARCHAR)",
      "snapshot_id": 2,
      "expected_state": {
        "ducklake_table": [
          {"table_id": 1, "schema_id": 1, "table_name": "test_table", "begin_snapshot": 2, "end_snapshot": null}
        ],
        "ducklake_column": [
          {"column_id": 1, "table_id": 1, "column_name": "id", "data_type": "INTEGER", "begin_snapshot": 2, "end_snapshot": null},
          {"column_id": 2, "table_id": 1, "column_name": "name", "data_type": "VARCHAR", "begin_snapshot": 2, "end_snapshot": null}
        ]
      }
    },
    {
      "step": 4,
      "operation": "insert",
      "sql": "INSERT INTO lake.main.test_table VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Charlie')",
      "snapshot_id": 3,
      "rows_affected": 3,
      "expected_state": {
        "ducklake_data_file": [
          {"data_file_id": 1, "table_id": 1, "file_path": "data/test_table/data_0.parquet", "record_count": 3, "begin_snapshot": 3, "end_snapshot": null}
        ]
      }
    },
    {
      "step": 5,
      "operation": "select",
      "sql": "SELECT * FROM lake.main.test_table",
      "expected_rows": [
        {"id": 1, "name": "Alice"},
        {"id": 2, "name": "Bob"},
        {"id": 3, "name": "Charlie"}
      ]
    },
    {
      "step": 6,
      "operation": "time_travel",
      "sql": "SELECT * FROM lake.main.test_table AT (SNAPSHOT 2)",
      "expected_rows": []
    },
    {
      "step": 7,
      "operation": "alter_table_add_column",
      "sql": "ALTER TABLE lake.main.test_table ADD COLUMN email VARCHAR",
      "snapshot_id": 4,
      "expected_state": {
        "ducklake_column": [
          {"column_id": 3, "table_id": 1, "column_name": "email", "data_type": "VARCHAR", "begin_snapshot": 4, "end_snapshot": null}
        ]
      }
    },
    {
      "step": 8,
      "operation": "drop_table",
      "sql": "DROP TABLE lake.main.test_table",
      "snapshot_id": 5,
      "expected_state": {
        "ducklake_table": [
          {"table_id": 1, "end_snapshot": 5}
        ],
        "ducklake_column": [
          {"column_id": 1, "end_snapshot": 5},
          {"column_id": 2, "end_snapshot": 5},
          {"column_id": 3, "end_snapshot": 5}
        ]
      }
    }
  ]
}
